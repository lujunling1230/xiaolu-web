# 解忧杂货铺 - AI 配置
# 复制此文件为 .env 并填入真实值

# 阿里云百炼 API Key
VITE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 阿里云 DashScope OpenAI 兼容接口地址
VITE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 模型名称（默认 deepseek-r1）
VITE_MODEL=deepseek-r1

# ================================================================
# 服务端环境变量（仅用于 Vercel Serverless Functions，不暴露给前端）
# 请在 Vercel 控制台 Project Settings -> Environment Variables 中配置
# ================================================================
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx
# GITHUB_REPO=xiaolu-web/portfolio
# GITHUB_BRANCH=main
