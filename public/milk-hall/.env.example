# ============================================
# 解忧杂货铺 - 环境变量配置模板
# 复制此文件为 .env 并填入你的实际值
# ============================================

# 阿里云百炼 API Key（在百炼控制台获取）
API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼 OpenAI 兼容接口地址
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型名称（DeepSeek）
MODEL=deepseek-v3
